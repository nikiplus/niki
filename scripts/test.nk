func calculate_total(base, multiplier, offset, arr_val) {
    var temp = base * multiplier;
    return temp + offset + arr_val; 
}

func main() {
    // 1. 变量与常量声明
    var a = 10;
    const b = 20;
    var c = a + b;//30

    // 2. 算术运算与一元操作
    var d = (c * 2 - 5) / 5; // 结果应该是 (30 * 2 - 5) / 5 = 55 / 5 = 11
    var e = -d;              // 结果应该是 -11

    // 3. 布尔逻辑与比较运算
    var is_greater = c > d;  // 30 > 11 -> true
    var is_equal = (a == 10); // true
    var logic_and = is_greater && is_equal; // true && true = true
    var logic_or = !is_greater || false;    // false || false = false

    // 3.5. 位运算
    var bit_and = a & b;     // 10 (1010) & 20 (10100) = 0
    var bit_or = a | b;      // 10 (1010) | 20 (10100) = 30 (11110)
    var bit_xor = a ^ b;     // 10 (1010) ^ 20 (10100) = 30 (11110)
    var bit_shl = a << 1;    // 10 << 1 = 20
    var bit_shr = b >> 1;    // 20 >> 1 = 10

    // 3.8. 字符串拼接 (使用专用的 .. 操作符)
    var str1 = "hello, ";
    var str2 = "NIKI";
    var str3 = str1 .. str2; // 产生一个新的堆分配字符串 "hello, NIKI"

    // 3.9. 数组操作 (Array)
    var arr = [10, 20, 30];
    arr[1] = 99;         // 写入数组 (Mutation)
    var arr_item = arr[1]; // 读取数组 (99)

    // 4. 控制流：If-Else
    var f = 0;
    if (is_greater) {
        f = 100;
    } else {
        f = 200;
    }

    // 5. 控制流：Loop 循环
    var counter = 0;
    var sum = 0;
    loop (counter < 5) {
        sum = sum + counter; // 0 + 1 + 2 + 3 + 4 = 10
        counter = counter + 1;
    }

    var final_result = calculate_total(f, 2, sum, arr_item); // 100 * 2 + 10 + 99 = 309

    return final_result;
}